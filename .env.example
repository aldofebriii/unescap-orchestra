# ── OpenAI-compatible LLM ──
OPENAI_BASE_URL=http://localhost:4000/v1
OPENAI_MODEL=vertex-claude-4-5-sonnet

# Safety cap on agent reasoning steps. The loop normally stops as soon as the
# LLM returns a response with no tool calls — this is only the upper bound for
# runaway loops. Default: 15.
MAX_ITERATIONS=15

# ── Server ──
PORT=3000
